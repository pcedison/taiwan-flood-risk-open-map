# Flood Risk local runtime configuration.
# Copy values into a local .env file and replace change-me values before deployment.
# Zeabur single-service preview:
# - Service type: Dockerfile
# - Root Directory: repository root
# - Build Command / Start Command: leave blank
# - Health Check: /health, not /ready until PostgreSQL and Redis are attached
# - NEXT_PUBLIC_API_BASE_URL should be empty in Zeabur single-service mode;
#   the web client will keep same-origin /v1 calls and Next rewrites proxy them.
# - NEXT_PUBLIC_BASEMAP_* values are client build-time inputs; configure them
#   before building the image or rebuild after changing the public basemap.
# See docs/runbooks/zeabur-single-service-env.md for the non-engineer checklist.

APP_ENV=local
DEPLOYMENT_SHA=
LOG_LEVEL=info

API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_BASEMAP_STYLE_URL=
NEXT_PUBLIC_BASEMAP_KIND=
NEXT_PUBLIC_BASEMAP_PMTILES_URL=
NEXT_PUBLIC_BASEMAP_RASTER_TILES=
NEXT_PUBLIC_BASEMAP_ATTRIBUTION=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_BEARER_TOKEN=

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=flood_risk
POSTGRES_USER=flood_risk
POSTGRES_PASSWORD=change-me-local
DATABASE_URL=postgresql://flood_risk:change-me-local@postgres:5432/flood_risk

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-local
MINIO_BUCKET_RAW_SNAPSHOTS=flood-risk-raw

PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-local
NODE_EXPORTER_PORT=9100

WORKER_QUEUE=default
WORKER_IDLE_SECONDS=60
SCHEDULER_INTERVAL_SECONDS=300
SCHEDULER_MAX_TICKS=
SCHEDULER_LEASE_TTL_SECONDS=600
WORKER_RUNTIME_FIXTURES_ENABLED=false
WORKER_RUNTIME_JOB_LEASE_SECONDS=300
WORKER_INSTANCE=local
WORKER_METRICS_TEXTFILE_PATH=
SCHEDULER_METRICS_TEXTFILE_PATH=

# Optional comma-separated production allowlist. Empty keeps legacy SOURCE_* flags/defaults.
# Terms-reviewed adapters still require SOURCE_TERMS_REVIEW_ACK=true; sample adapters still
# require SOURCE_SAMPLE_DATA_ENABLED=true.
WORKER_ENABLED_ADAPTER_KEYS=

SOURCE_CWA_ENABLED=false
SOURCE_WRA_ENABLED=false
SOURCE_FLOOD_POTENTIAL_ENABLED=false
# Civil IoT Taiwan (ci.taiwan.gov.tw) SensorThings sources, disabled by default.
SOURCE_FLOOD_SENSOR_ENABLED=false
SOURCE_CIVIL_IOT_RIVER_ENABLED=false
SOURCE_CIVIL_IOT_POND_ENABLED=false
SOURCE_CIVIL_IOT_SEWER_ENABLED=false
SOURCE_CIVIL_IOT_PUMP_ENABLED=false
SOURCE_NEWS_ENABLED=false
SOURCE_FORUM_ENABLED=false
SOURCE_PTT_ENABLED=false
SOURCE_DCARD_ENABLED=false
SOURCE_PTT_CANDIDATE_APPROVAL_ACK=false
SOURCE_DCARD_CANDIDATE_APPROVAL_ACK=false
SOURCE_TERMS_REVIEW_ACK=false
SOURCE_SAMPLE_DATA_ENABLED=false

# Local smoke/E2E can disable DB-backed evidence reads, persistence, and query
# heat while still exercising local fallback records.
EVIDENCE_REPOSITORY_ENABLED=true

# Optional comma-separated CSV/JSONL files for project-controlled open-data
# geocoding. Columns/keys: name,address/road_name/poi_name,aliases,lat,lng,
# admin_code,precision,type,source. TGOS is not required for this path.
GEOCODER_OPEN_DATA_PATHS=
GEOCODER_BUNDLED_OPEN_DATA_ENABLED=true
GEOCODER_POSTGIS_ENABLED=false
GEOCODER_POSTGIS_BOOTSTRAP_ENABLED=false

# Bounded GDELT public-news rehearsal / production-candidate controls.
# Keep all disabled until source/legal review, egress cadence, and alert ownership are accepted.
# Production-candidate runs require both a concrete external evidence path and ACK=true.
GDELT_SOURCE_ENABLED=false
GDELT_BACKFILL_ENABLED=false
GDELT_REHEARSAL_QUERIES=
GDELT_REHEARSAL_MAX_RECORDS_PER_QUERY=10
GDELT_REHEARSAL_CADENCE_SECONDS=60
GDELT_PRODUCTION_INGESTION_ENABLED=false
GDELT_PRODUCTION_APPROVAL_EVIDENCE_PATH=
GDELT_PRODUCTION_APPROVAL_EVIDENCE_ACK=false
GDELT_PRODUCTION_QUERIES=
GDELT_PRODUCTION_MAX_RECORDS_PER_QUERY=10
GDELT_PRODUCTION_CADENCE_SECONDS=60

# Public API on-demand historical news enrichment.
# Local preview defaults may enable this when APP_ENV=local; production must keep explicit
# source/legal ACKs, bounded max records, and a kill switch.
HISTORICAL_NEWS_ON_DEMAND_ENABLED=true
HISTORICAL_NEWS_ON_DEMAND_WRITEBACK_ENABLED=true
HISTORICAL_NEWS_ON_DEMAND_MAX_RECORDS=5
HISTORICAL_NEWS_ON_DEMAND_TIMEOUT_SECONDS=4
RISK_ASSESSMENT_RESPONSE_CACHE_SECONDS=0
# redis|memory. Hosted runtimes default to redis (shared across replicas, fails
# open to process memory); local/test default to memory.
RISK_ASSESSMENT_RESPONSE_CACHE_BACKEND=memory
# Local/test-only runtime MVT fallback. Hosted environments default to false.
TILE_DYNAMIC_FALLBACK_ENABLED=true

# Runtime public risk API realtime observations.
# Uses official CWA rainfall and WRA water-level open data for nearby station evidence.
# data.gov.tw is the primary public catalog reference:
# - rainfall: https://data.gov.tw/dataset/9177 (CWA O-A0002-001 resource)
# - water level: https://data.gov.tw/dataset/25768 (WRA realtime resource)
# REALTIME_OFFICIAL_ENABLED is the global switch; individual source gates below
# must also be true before live CWA/WRA HTTP calls are made.
REALTIME_OFFICIAL_ENABLED=true
CWA_API_AUTHORIZATION=
OFFICIAL_REALTIME_FETCH_TIMEOUT_SECONDS=3
OFFICIAL_REALTIME_CACHE_STALE_SECONDS=1800

# Worker official ingestion live-client gates. In the Zeabur single-service
# Dockerfile, `auto` starts the scheduler when `DATABASE_URL`/`WORKER_DATABASE_URL`
# is attached; set `false` as an explicit kill switch.
# See docs/data-sources/official/official-source-catalog.yaml for the
# data.gov.tw dataset IDs, resource URLs, licenses, and limitations.
HOSTED_INGESTION_SCHEDULER_ENABLED=auto
REALTIME_BACKBONE_FORCE_INGESTION_ON_START=true
REALTIME_BACKBONE_INGESTION_DISABLED=false
REALTIME_BACKBONE_ADAPTER_KEYS=official.cwa.rainfall,official.cwa.tide_level,official.wra.water_level,official.wra_iow.flood_depth,official.ncdr.cap,official.civil_iot.flood_sensor,official.civil_iot.sewer_water_level,official.civil_iot.pump_water_level,official.civil_iot.gate_water_level
RUN_DATABASE_MIGRATIONS_ON_START=true
WORKER_ENABLED_ADAPTER_KEYS=official.cwa.rainfall,official.cwa.tide_level,official.wra.water_level,official.wra_iow.flood_depth,official.ncdr.cap,official.civil_iot.flood_sensor,official.civil_iot.sewer_water_level,official.civil_iot.pump_water_level,official.civil_iot.gate_water_level
SCHEDULER_INTERVAL_SECONDS=300
SCHEDULER_LEASE_TTL_SECONDS=600
# Prune realtime official rainfall/water_level evidence older than this many
# hours during scheduler maintenance, so live ingestion stays bounded on a
# small node. Historical evidence is never pruned by this.
EVIDENCE_REALTIME_RETENTION_HOURS=48
# ADR-0006: location_queries rows only hold coarse (~1 km) buckets, and even
# those are pruned after this many hours (default 30 days, comfortably above
# the P7D live query-heat window). Cascades clean up linked assessments.
LOCATION_QUERIES_RETENTION_HOURS=720
WORKER_DATABASE_URL=
SOURCE_CWA_API_ENABLED=false
CWA_API_URL=
CWA_API_TIMEOUT_SECONDS=8
SOURCE_WRA_API_ENABLED=false
WRA_API_URL=
WRA_STATION_API_URL=
WRA_API_TOKEN=
WRA_API_TIMEOUT_SECONDS=8
SOURCE_WRA_IOW_FLOOD_DEPTH_API_ENABLED=false
SOURCE_NCDR_CAP_API_ENABLED=false
SOURCE_FLOOD_POTENTIAL_GEOJSON_ENABLED=false
FLOOD_POTENTIAL_GEOJSON_URL=
FLOOD_POTENTIAL_GEOJSON_TIMEOUT_SECONDS=8
# Civil IoT Taiwan SensorThings live fetch (needs the gate flags above too).
# URLs are optional; blank uses the built-in default STA query per adapter.
SOURCE_FLOOD_SENSOR_API_ENABLED=false
CIVIL_IOT_FLOOD_SENSOR_URL=
SOURCE_CIVIL_IOT_RIVER_API_ENABLED=false
CIVIL_IOT_RIVER_URL=
SOURCE_CIVIL_IOT_POND_API_ENABLED=false
CIVIL_IOT_POND_URL=
SOURCE_CIVIL_IOT_SEWER_API_ENABLED=false
CIVIL_IOT_SEWER_URL=
SOURCE_CIVIL_IOT_PUMP_API_ENABLED=false
CIVIL_IOT_PUMP_URL=
SOURCE_CIVIL_IOT_GATE_API_ENABLED=false
CIVIL_IOT_GATE_URL=
CIVIL_IOT_API_TIMEOUT_SECONDS=8

# Local-government realtime water adapters. These are disabled by default and
# require both WORKER_ENABLED_ADAPTER_KEYS inclusion and the paired source/API gates.
LOCAL_WATER_TIMEOUT_SECONDS=8
SOURCE_NEW_TAIPEI_WATER_LEVEL_ENABLED=false
SOURCE_NEW_TAIPEI_WATER_LEVEL_API_ENABLED=false
NEW_TAIPEI_WATER_LEVEL_API_URL=
SOURCE_NEW_TAIPEI_FLOOD_SENSOR_ENABLED=false
SOURCE_NEW_TAIPEI_FLOOD_SENSOR_API_ENABLED=false
NEW_TAIPEI_FLOOD_SENSOR_API_URL=
SOURCE_NEW_TAIPEI_RAINFALL_ENABLED=false
SOURCE_NEW_TAIPEI_RAINFALL_API_ENABLED=false
NEW_TAIPEI_RAINFALL_API_URL=
SOURCE_NEW_TAIPEI_DRAINAGE_WATER_LEVEL_ENABLED=false
SOURCE_NEW_TAIPEI_DRAINAGE_WATER_LEVEL_API_ENABLED=false
NEW_TAIPEI_DRAINAGE_WATER_LEVEL_API_URL=
SOURCE_KEELUNG_WATER_LEVEL_ENABLED=false
SOURCE_KEELUNG_WATER_LEVEL_API_ENABLED=false
KEELUNG_WATER_LEVEL_API_URL=
SOURCE_KEELUNG_FLOOD_SENSOR_ENABLED=false
SOURCE_KEELUNG_FLOOD_SENSOR_API_ENABLED=false
KEELUNG_FLOOD_SENSOR_API_URL=
SOURCE_KEELUNG_RAINFALL_ENABLED=false
SOURCE_KEELUNG_RAINFALL_API_ENABLED=false
KEELUNG_RAINFALL_API_URL=
SOURCE_YUNLIN_WATER_LEVEL_ENABLED=false
SOURCE_YUNLIN_WATER_LEVEL_API_ENABLED=false
YUNLIN_STATIONS_API_URL=
SOURCE_KAOHSIUNG_SEWER_WATER_LEVEL_ENABLED=false
SOURCE_KAOHSIUNG_SEWER_WATER_LEVEL_API_ENABLED=false
KAOHSIUNG_SEWER_WATER_LEVEL_API_URL=
SOURCE_KAOHSIUNG_FLOOD_SENSOR_ENABLED=false
SOURCE_KAOHSIUNG_FLOOD_SENSOR_API_ENABLED=false
KAOHSIUNG_FLOOD_SENSOR_API_URL=
SOURCE_KAOHSIUNG_RAINFALL_ENABLED=false
SOURCE_KAOHSIUNG_RAINFALL_API_ENABLED=false
KAOHSIUNG_RAINFALL_RT_API_URL=
KAOHSIUNG_RAINFALL_BASE_API_URL=
SOURCE_PENGHU_WATER_LEVEL_ENABLED=false
SOURCE_PENGHU_WATER_LEVEL_API_ENABLED=false
PENGHU_WATER_LEVEL_LAYER_URL=
SOURCE_KINMEN_KWIS_PUMP_STATION_ENABLED=false
SOURCE_KINMEN_KWIS_PUMP_STATION_API_ENABLED=false
KINMEN_KWIS_PUMP_STATION_API_URL=
# Requires formal Kinmen County / KWIS read-side authorization. Do not set this
# from upload-only credentials or public blank-token smoke results.
KINMEN_KWIS_API_TOKEN=
SOURCE_HSINCHU_COUNTY_FHY_FLOOD_SENSOR_ENABLED=false
SOURCE_HSINCHU_COUNTY_FHY_FLOOD_SENSOR_API_ENABLED=false
SOURCE_MIAOLI_FHY_FLOOD_SENSOR_ENABLED=false
SOURCE_MIAOLI_FHY_FLOOD_SENSOR_API_ENABLED=false
SOURCE_CHANGHUA_FHY_FLOOD_SENSOR_ENABLED=false
SOURCE_CHANGHUA_FHY_FLOOD_SENSOR_API_ENABLED=false
SOURCE_PINGTUNG_FHY_FLOOD_SENSOR_ENABLED=false
SOURCE_PINGTUNG_FHY_FLOOD_SENSOR_API_ENABLED=false
SOURCE_HUALIEN_FHY_FLOOD_SENSOR_ENABLED=false
SOURCE_HUALIEN_FHY_FLOOD_SENSOR_API_ENABLED=false
SOURCE_TAITUNG_FHY_FLOOD_SENSOR_ENABLED=false
SOURCE_TAITUNG_FHY_FLOOD_SENSOR_API_ENABLED=false
FHY_FLOOD_SENSOR_STATION_API_URL=
FHY_FLOOD_SENSOR_REALTIME_API_URL=

# Public endpoint rate limiting (geocode / risk assess). In hosted runtimes
# the API sits behind the Next.js server-side proxy, so the raw socket peer is
# always 127.0.0.1 — set the client header so limits apply per real client.
# The app uses the RIGHT-most non-proxy entry of the header (spoof-safe);
# loopback/private ranges are always treated as proxy hops. If you add a
# public-IP proxy layer (e.g. a CDN), list its egress ranges as CIDRs below.
PUBLIC_RATE_LIMIT_CLIENT_HEADER=X-Forwarded-For
PUBLIC_RATE_LIMIT_TRUSTED_PROXY_CIDRS=

# Phase 5 user report intake groundwork. Keep disabled until legal/privacy,
# moderation, retention, abuse-prevention, and deletion gates are approved.
USER_REPORTS_ENABLED=false
USER_REPORTS_RATE_LIMIT_ENABLED=true
USER_REPORTS_RATE_LIMIT_BACKEND=redis
USER_REPORTS_RATE_LIMIT_MAX_REQUESTS=5
USER_REPORTS_RATE_LIMIT_WINDOW_SECONDS=60
USER_REPORTS_RATE_LIMIT_CLIENT_HEADER=
ABUSE_HASH_SALT=
USER_REPORTS_CHALLENGE_REQUIRED=false
USER_REPORTS_CHALLENGE_PROVIDER=turnstile
USER_REPORTS_CHALLENGE_SECRET_KEY=
USER_REPORTS_CHALLENGE_STATIC_TOKEN=
USER_REPORTS_CHALLENGE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
USER_REPORTS_CHALLENGE_TIMEOUT_SECONDS=2
USER_REPORTS_CHALLENGE_NON_PRODUCTION_BYPASS=false
